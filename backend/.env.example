# Velpos Backend 环境变量配置
# 复制此文件为 .env 并按需修改

# 数据库连接（本地开发连 Docker MySQL）
DATABASE_URL=mysql+aiomysql://root:yourpassword@localhost:3307/velpos

# Claude Agent SDK
CLAUDE_CLI_PATH=/path/to/claude
CLAUDE_PERMISSION_MODE=acceptEdits
CLAUDE_MAX_BUFFER_SIZE=10485760

# 默认模型
DEFAULT_MODEL=claude-opus-4-6

# 服务器
SERVER_HOST=0.0.0.0
SERVER_PORT=8083

# CORS
CORS_ALLOW_ORIGINS=*

# 会话项目根目录
PROJECTS_ROOT_DIR=~/claude-projects
